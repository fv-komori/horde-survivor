{
  "name": "fv-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .ts",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "audit": "npm audit --audit-level=high",
    "size": "size-limit",
    "check": "npm run lint && npm test && npm run build && npm run size"
  },
  "size-limit": [
    {
      "path": "dist/assets/index-*.js",
      "limit": "215 KB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@size-limit/preset-app": "^12.1.0",
    "@types/jest": "^29.5.12",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "gltf-pipeline": "^4.3.1",
    "jest": "^29.7.0",
    "size-limit": "^12.1.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "three": "^0.183.2"
  }
}
